<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="application" source="spring.application.name" defaultValue="dogs-web-api"/>
    <springProperty scope="context" name="version" source="service.version" defaultValue="unknown"/>

    <property name="CONSOLE_LOG_PATTERN"
              value="${CONSOLE_LOG_PATTERN:-%d{yyyy-MM-dd HH:mm:ss.SSS} %5p ${PID:- } --- [%15.15t] %-40.40logger{39} : %m%n}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <withJansi>false</withJansi>
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Default root -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Local profile: verbose -->
    <springProfile name="local">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.dogs.api" level="DEBUG"/>
        <logger name="org.springframework.web" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="WARN"/>
    </springProfile>

    <!-- Test profile -->
    <springProfile name="test">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.dogs.api" level="INFO"/>
        <logger name="org.springframework.web" level="WARN"/>
    </springProfile>

    <!-- Prod profile: minimal noise -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.dogs.api" level="INFO"/>
        <logger name="org.springframework.web" level="ERROR"/>
        <logger name="org.hibernate" level="WARN"/>
    </springProfile>
</configuration>
